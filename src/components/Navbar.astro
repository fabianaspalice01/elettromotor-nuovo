---
const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  if (path === "/") return currentPath === "/";
  return currentPath.startsWith(path);
};
---

<header class="site-header">
  <div class="container navigation">
    <a class="logo" href="/" aria-label="Homepage Elettromotor">
      <img
        src="/images/logo-elettromotor.png"
        alt="Elettromotor"
        class="logo-image"
      />

      
    </a>

    <nav class="menu" aria-label="Navigazione principale">
      <a
        href="/"
        class:list={["nav-link", { active: isActive("/") }]}
      >
        Home
      </a>

      <a
        href="/azienda/"
        class:list={["nav-link", { active: isActive("/azienda/") }]}
      >
        Azienda
      </a>

      <div class="dropdown">
        <button
          type="button"
          class:list={[
            "nav-link",
            "dropdown-button",
            { active: isActive("/servizi/") },
          ]}
        >
          Servizi
          <span aria-hidden="true">⌄</span>
        </button>

        <div class="dropdown-menu">
          <a href="/servizi/installazioni/">Installazioni</a>
          <a href="/servizi/manutenzioni/">Manutenzioni</a>
          <a href="/servizi/progettazione/">Progettazione</a>
        </div>
      </div>

      <a
        href="/certificazioni/"
        class:list={["nav-link", { active: isActive("/certificazioni/") }]}
      >
        Certificazioni
      </a>

      <a
        href="/blog/"
        class:list={["nav-link", { active: isActive("/blog/") }]}
      >
        Blog
      </a>

      <a
        href="/contatti/"
        class:list={["nav-link", { active: isActive("/contatti/") }]}
      >
        Contatti
      </a>
    </nav>

    <a class="header-button" href="/contatti/">
      Richiedi un sopralluogo
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.97);
    border-bottom: 1px solid #dbe3ea;
    backdrop-filter: blur(12px);
  }

  .container {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .navigation {
    min-height: 96px;
    display: flex;
    align-items: center;
    gap: 35px;
  }

  .logo {
    margin-right: auto;
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .logo-image {
    width: 82px;
    height: auto;
    display: block;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo-text strong {
    color: #07182e;
    font-size: 18px;
    letter-spacing: 0.7px;
  }

  .logo-text small {
    margin-top: 4px;
    color: #667385;
    font-size: 11px;
  }

  .menu {
    display: flex;
    align-items: center;
    gap: 25px;
  }

  .nav-link {
    padding: 38px 0 35px;
    color: #07182e;
    background: transparent;
    border: 0;
    border-bottom: 3px solid transparent;
    font: inherit;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #0878d1;
    border-bottom-color: #0878d1;
  }

  .dropdown {
    position: relative;
  }

  .dropdown-button {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% - 1px);
    left: -20px;
    min-width: 210px;
    padding: 10px;
    display: none;
    background: #ffffff;
    border: 1px solid #dbe3ea;
    border-radius: 8px;
    box-shadow: 0 18px 40px rgba(7, 24, 46, 0.16);
  }

  .dropdown:hover .dropdown-menu,
  .dropdown:focus-within .dropdown-menu {
    display: block;
  }

  .dropdown-menu a {
    padding: 12px 14px;
    display: block;
    color: #182536;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
  }

  .dropdown-menu a:hover {
    color: #0878d1;
    background: #f4f7fa;
  }

  .header-button {
    padding: 13px 19px;
    color: #ffffff;
    background: #07182e;
    border-radius: 7px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 1000px) {
    .menu,
    .header-button {
      display: none;
    }
  }
</style>
