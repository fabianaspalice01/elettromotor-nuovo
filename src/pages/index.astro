---
import BaseLayout from "../layouts/BaseLayout.astro";

const services = [
  {
    number: "01",
    title: "Impianti antincendio",
    description:
      "Installazione e manutenzione di sistemi antincendio, estintori, idranti, NASPI e porte REI.",
    href: "/servizi/installazioni/",
  },
  {
    number: "02",
    title: "Sollevamento idrico",
    description:
      "Realizzazione, assistenza e manutenzione di gruppi di pressurizzazione e impianti idrici.",
    href: "/servizi/installazioni/",
  },
  {
    number: "03",
    title: "Pulizia serbatoi",
    description:
      "Interventi professionali di pulizia, controllo e manutenzione dei serbatoi idrici.",
    href: "/servizi/manutenzioni/",
  },
  {
    number: "04",
    title: "Riavvolgimento motori",
    description:
      "Riparazione e riavvolgimento di motori elettrici per applicazioni civili e industriali.",
    href: "/servizi/manutenzioni/",
  },
  {
    number: "05",
    title: "Manutenzione programmata",
    description:
      "Controlli periodici per mantenere gli impianti efficienti, sicuri e conformi.",
    href: "/servizi/manutenzioni/",
  },
  {
    number: "06",
    title: "Progettazione",
    description:
      "Soluzioni tecniche studiate sulla base delle esigenze dell’attività e dell’impianto.",
    href: "/servizi/progettazione/",
  },
];
---

<BaseLayout
  title="Elettromotor | Impianti e manutenzione"
  description="Elettromotor: installazione, manutenzione e progettazione di impianti tecnologici e antincendio."
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <span class="eyebrow">Dal 1990 al servizio delle aziende</span>

        <h1>
          Tecnologia e professionalità
          <span>per la tua sicurezza.</span>
        </h1>

        <p>
          Installazione, progettazione e manutenzione di impianti tecnologici,
          sistemi antincendio e soluzioni elettromeccaniche.
        </p>

        <div class="hero-actions">
          <a class="button primary" href="#servizi">
            Scopri i servizi
          </a>

          <a class="button secondary" href="#contatti">
            Contattaci
          </a>
        </div>

        <div class="hero-data">
          <div>
            <strong>30+</strong>
            <span>Anni di esperienza</span>
          </div>

          <div>
            <strong>360°</strong>
            <span>Assistenza completa</span>
          </div>

          <div>
            <strong>24h</strong>
            <span>Supporto tecnico</span>
          </div>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="visual-panel">
          <span class="visual-label">ELETTROMOTOR</span>

          <div class="visual-circle">
            <div class="visual-inner"></div>
          </div>

          <p>Impianti affidabili.<br />Sicurezza continua.</p>
        </div>

        <div class="floating-card">
          <span>✓</span>

          <div>
            <strong>Manutenzione programmata</strong>
            <small>Efficienza e controllo nel tempo</small>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="intro" id="azienda">
    <div class="container intro-grid">
      <div>
        <span class="section-label">Chi siamo</span>

        <h2>Esperienza tecnica, attenzione e affidabilità.</h2>
      </div>

      <div class="intro-text">
        <p>
          Elettromotor nasce nel settore dell’elettromeccanica industriale e
          sviluppa nel tempo competenze nella realizzazione e nella
          manutenzione di impianti tecnologici.
        </p>

        <p>
          Seguiamo ogni intervento dalla valutazione iniziale alla
          manutenzione periodica, offrendo un unico referente per tutte le
          esigenze tecniche.
        </p>

        <a class="text-link" href="/azienda/">
          Scopri l’azienda →
        </a>
      </div>
    </div>
  </section>

  <section class="services" id="servizi">
    <div class="container">
      <div class="section-heading">
        <div>
          <span class="section-label light">I nostri servizi</span>

          <h2>Soluzioni costruite intorno alle tue esigenze.</h2>
        </div>

        <p>
          Interventi completi per attività commerciali, industrie, condomini
          ed enti.
        </p>
      </div>

      <div class="services-grid">
        {
          services.map((service) => (
            <article class="service-card">
              <span class="service-number">{service.number}</span>

              <h3>{service.title}</h3>

              <p>{service.description}</p>

              <a href={service.href} aria-label={`Informazioni su ${service.title}`}>
                Maggiori informazioni
                <span>→</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="maintenance" id="manutenzione">
    <div class="container maintenance-grid">
      <div class="maintenance-image">
        <div class="maintenance-decoration"></div>

        <div class="maintenance-box">
          <span>Controllo</span>
          <strong>Prevenire è più sicuro che intervenire.</strong>
        </div>
      </div>

      <div class="maintenance-content">
        <span class="section-label">Manutenzione</span>

        <h2>Mantieni sempre efficienti i tuoi impianti.</h2>

        <p>
          Un programma di manutenzione regolare permette di ridurre i
          guasti, migliorare la sicurezza e prolungare la durata delle
          apparecchiature.
        </p>

        <ul>
          <li>Controlli periodici programmati</li>
          <li>Verifica dello stato degli impianti</li>
          <li>Interventi tecnici e sostituzione componenti</li>
          <li>Assistenza e tracciabilità delle manutenzioni</li>
        </ul>

        <a class="button dark" href="/servizi/manutenzioni/">
          Scopri le manutenzioni
        </a>
      </div>
    </div>
  </section>

  <section class="contact" id="contatti">
    <div class="container contact-box">
      <div>
        <span class="section-label light">Contatti</span>

        <h2>Hai bisogno di assistenza o di un sopralluogo?</h2>

        <p>
          Raccontaci di cosa hai bisogno. Ti ricontatteremo per valutare
          insieme la soluzione più adatta.
        </p>
      </div>

      <div class="contact-actions">
        <a class="button white" href="mailto:info@elettromotor.net">
          info@elettromotor.net
        </a>

        <a class="contact-phone" href="tel:+390000000000">
          Inserire primo numero di telefono
        </a>

        <a class="contact-phone" href="tel:+390000000001">
          Inserire secondo numero di telefono
        </a>

        <div class="social-links" aria-label="Canali social Elettromotor">
          <a
            href="https://www.facebook.com/elettromotor1"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook Elettromotor"
          >
            Facebook
          </a>

          <a
            href="https://www.instagram.com/elettromotor"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram Elettromotor"
          >
            Instagram
          </a>

          <a
            href="https://www.linkedin.com/company/elettromotorsrl/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn Elettromotor"
          >
            LinkedIn
          </a>

          <a
            href="https://wa.me/39NUMERODITELEFONO"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Contatta Elettromotor su WhatsApp"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    overflow: hidden;
    padding: 90px 0;
    background:
      radial-gradient(
        circle at 85% 20%,
        rgba(41, 184, 239, 0.17),
        transparent 30%
      ),
      linear-gradient(135deg, #f9fbfd 0%, #edf4f9 100%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    align-items: center;
    gap: 80px;
  }

  .eyebrow,
  .section-label {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.8px;
    text-transform: uppercase;
  }

  .section-label.light {
    color: var(--cyan);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 720px;
    margin-bottom: 24px;
    color: var(--navy);
    font-size: clamp(48px, 6vw, 78px);
    line-height: 0.98;
    letter-spacing: -3px;
  }

  h1 span {
    display: block;
    color: var(--blue);
  }

  .hero-content > p {
    max-width: 650px;
    margin-bottom: 34px;
    color: var(--muted);
    font-size: 19px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .button {
    min-height: 52px;
    padding: 0 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 7px;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button.primary {
    color: var(--white);
    background: var(--blue);
    box-shadow: 0 14px 30px rgba(8, 120, 209, 0.22);
  }

  .button.secondary {
    color: var(--navy);
    background: var(--white);
    border: 1px solid var(--border);
  }

  .button.dark {
    color: var(--white);
    background: var(--navy);
  }

  .button.white {
    color: var(--navy);
    background: var(--white);
  }

  .hero-data {
    margin-top: 52px;
    padding-top: 28px;
    display: flex;
    gap: 36px;
    border-top: 1px solid var(--border);
  }

  .hero-data div {
    display: flex;
    flex-direction: column;
  }

  .hero-data strong {
    color: var(--navy);
    font-size: 28px;
  }

  .hero-data span {
    margin-top: 5px;
    color: var(--muted);
    font-size: 12px;
  }

  .hero-visual {
    position: relative;
    min-height: 510px;
  }

  .visual-panel {
    min-height: 490px;
    padding: 42px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--white);
    background:
      linear-gradient(150deg, rgba(7, 24, 46, 0.92), rgba(8, 120, 209, 0.82)),
      var(--navy);
    border-radius: 22px;
    box-shadow: 0 30px 70px rgba(7, 24, 46, 0.25);
  }

  .visual-label {
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 2px;
  }

  .visual-circle {
    width: 230px;
    height: 230px;
    margin: auto;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
  }

  .visual-inner {
    width: 150px;
    height: 150px;
    border: 25px solid rgba(255, 255, 255, 0.92);
    border-right-color: var(--cyan);
    border-radius: 50%;
    transform: rotate(-30deg);
  }

  .visual-panel p {
    margin: 0;
    font-size: 29px;
    font-weight: 800;
    line-height: 1.15;
  }

  .floating-card {
    position: absolute;
    right: -35px;
    bottom: 42px;
    width: 285px;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 15px;
    background: var(--white);
    border-radius: 12px;
    box-shadow: 0 18px 45px rgba(7, 24, 46, 0.2);
  }

  .floating-card > span {
    width: 42px;
    height: 42px;
    flex: 0 0 42px;
    display: grid;
    place-items: center;
    color: var(--white);
    background: var(--blue);
    border-radius: 50%;
    font-weight: 900;
  }

  .floating-card div {
    display: flex;
    flex-direction: column;
  }

  .floating-card strong {
    color: var(--navy);
    font-size: 14px;
  }

  .floating-card small {
    margin-top: 5px;
    color: var(--muted);
    font-size: 11px;
  }

  .intro,
  .maintenance {
    padding: 110px 0;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 100px;
  }

  h2 {
    color: var(--navy);
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.08;
    letter-spacing: -1.8px;
  }

  .intro-text p,
  .maintenance-content > p {
    color: var(--muted);
    font-size: 17px;
    line-height: 1.8;
  }

  .text-link {
    margin-top: 12px;
    display: inline-block;
    color: var(--blue);
    font-weight: 800;
    text-decoration: none;
  }

  .services {
    padding: 110px 0;
    color: var(--white);
    background: var(--navy);
  }

  .section-heading {
    margin-bottom: 50px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: end;
    gap: 60px;
  }

  .section-heading h2 {
    max-width: 720px;
    margin-bottom: 0;
    color: var(--white);
  }

  .section-heading > p {
    margin-bottom: 6px;
    color: #aebdd0;
    font-size: 16px;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .service-card {
    min-height: 310px;
    padding: 30px;
    display: flex;
    flex-direction: column;
    background: var(--navy-light);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    transition:
      transform 0.25s ease,
      background 0.25s ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
    background: #13365e;
  }

  .service-number {
    margin-bottom: 55px;
    color: var(--cyan);
    font-size: 12px;
    font-weight: 800;
  }

  .service-card h3 {
    margin-bottom: 14px;
    font-size: 22px;
  }

  .service-card p {
    color: #aebdd0;
    font-size: 14px;
    line-height: 1.7;
  }

  .service-card a {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    color: var(--white);
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
  }

  .service-card a span {
    color: var(--cyan);
    font-size: 20px;
  }

  .maintenance {
    background: var(--background);
  }

  .maintenance-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 90px;
  }

  .maintenance-image {
    position: relative;
    min-height: 530px;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      rgba(8, 120, 209, 0.96),
      rgba(7, 24, 46, 0.94)
    );
    border-radius: 20px;
  }

  .maintenance-decoration {
    position: absolute;
    top: 80px;
    right: -100px;
    width: 390px;
    height: 390px;
    border: 70px solid rgba(255, 255, 255, 0.12);
    border-radius: 50%;
  }

  .maintenance-box {
    position: absolute;
    left: 38px;
    right: 38px;
    bottom: 38px;
    padding: 30px;
    color: var(--white);
    background: rgba(7, 24, 46, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 12px;
    backdrop-filter: blur(8px);
  }

  .maintenance-box span {
    margin-bottom: 12px;
    display: block;
    color: var(--cyan);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .maintenance-box strong {
    font-size: 26px;
    line-height: 1.25;
  }

  .maintenance-content ul {
    margin: 28px 0 34px;
    padding: 0;
    list-style: none;
  }

  .maintenance-content li {
    position: relative;
    padding: 13px 0 13px 28px;
    border-bottom: 1px solid var(--border);
    font-size: 15px;
    font-weight: 700;
  }

  .maintenance-content li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--blue);
  }

  .contact {
    padding: 50px 0;
    background: var(--white);
  }

  .contact-box {
    padding: 65px;
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    align-items: center;
    gap: 60px;
    color: var(--white);
    background: linear-gradient(135deg, var(--blue), #035fa7);
    border-radius: 20px;
  }

  .contact-box h2 {
    max-width: 720px;
    margin-bottom: 18px;
    color: var(--white);
  }

  .contact-box p {
    max-width: 700px;
    margin-bottom: 0;
    color: #d8edff;
    line-height: 1.7;
  }

  .contact-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
  }

  .contact-phone {
    color: var(--white);
    font-weight: 700;
    text-decoration: none;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .social-links a {
    padding: 10px 14px;
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .social-links a:hover {
    color: var(--blue);
    background: var(--white);
    transform: translateY(-2px);
  }

  @media (max-width: 950px) {
    .hero-grid,
    .intro-grid,
    .maintenance-grid,
    .contact-box,
    .section-heading {
      grid-template-columns: 1fr;
      gap: 45px;
    }

    .hero-visual {
      min-height: auto;
    }

    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .floating-card {
      right: 20px;
    }
  }

  @media (max-width: 620px) {
    .hero {
      padding: 65px 0;
    }

    h1 {
      font-size: 47px;
      letter-spacing: -2px;
    }

    h2 {
      font-size: 36px;
    }

    .hero-data {
      gap: 18px;
    }

    .hero-data strong {
      font-size: 22px;
    }

    .hero-data span {
      font-size: 10px;
    }

    .visual-panel {
      min-height: 430px;
      padding: 28px;
    }

    .visual-circle {
      width: 190px;
      height: 190px;
    }

    .visual-inner {
      width: 120px;
      height: 120px;
    }

    .floating-card {
      position: relative;
      right: auto;
      bottom: auto;
      width: calc(100% - 30px);
      margin: -30px auto 0;
    }

    .intro,
    .services,
    .maintenance {
      padding: 75px 0;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      min-height: 280px;
    }

    .maintenance-image {
      min-height: 430px;
    }

    .contact {
      padding: 25px 0;
    }

    .contact-box {
      padding: 38px 25px;
    }
  }
</style>
