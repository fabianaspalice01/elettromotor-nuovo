---
import BaseLayout from "../../layouts/BaseLayout.astro";

const installations = [
  {
    number: "01",
    title: "Impianti antincendio",
    description:
      "Realizzazione e installazione di sistemi antincendio progettati in base alle caratteristiche dell’attività e dell’edificio.",
  },
  {
    number: "02",
    title: "Sollevamento idrico",
    description:
      "Installazione di gruppi di pressurizzazione, elettropompe e sistemi destinati alla distribuzione e al sollevamento dell’acqua.",
  },
  {
    number: "03",
    title: "Serbatoi idrici",
    description:
      "Installazione e adeguamento di serbatoi, sistemi di accumulo e componenti collegati agli impianti idrici.",
  },
  {
    number: "04",
    title: "Motori elettrici",
    description:
      "Installazione, sostituzione e ripristino di motori elettrici per applicazioni civili, industriali e condominiali.",
  },
];
---

<BaseLayout
  title="Installazioni | Elettromotor"
  description="Installazione di impianti antincendio, sistemi di sollevamento idrico, serbatoi e motori elettrici."
>
  <section class="page-hero">
    <div class="container hero-content">
      <span class="eyebrow">I nostri servizi</span>

      <h1>
        Installazioni affidabili
        <strong>per impianti sicuri ed efficienti.</strong>
      </h1>

      <p>
        Seguiamo ogni intervento dalla valutazione iniziale fino alla posa in
        opera e alla verifica finale dell’impianto.
      </p>

      <a class="hero-button" href="/contatti/">
        Richiedi un sopralluogo
      </a>
    </div>
  </section>

  <section class="services-section">
    <div class="container">
      <div class="section-heading">
        <div>
          <span class="section-label">Ambiti di intervento</span>

          <h2>Soluzioni tecniche studiate per ogni esigenza.</h2>
        </div>

        <p>
          Realizziamo impianti e sistemi destinati ad aziende, condomini,
          attività commerciali, industrie ed enti.
        </p>
      </div>

      <div class="services-grid">
        {
          installations.map((service) => (
            <article class="service-card">
              <span class="service-number">{service.number}</span>

              <h3>{service.title}</h3>

              <p>{service.description}</p>

              <a href="/contatti/">
                Richiedi informazioni
                <span>→</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="process-section">
    <div class="container process-grid">
      <div class="process-intro">
        <span class="section-label">Il nostro metodo</span>

        <h2>Dall’analisi iniziale alla messa in funzione.</h2>

        <p>
          Ogni installazione viene organizzata in modo da garantire chiarezza,
          controllo delle lavorazioni e continuità dell’assistenza.
        </p>
      </div>

      <div class="steps">
        <article class="step">
          <span>01</span>

          <div>
            <h3>Sopralluogo</h3>
            <p>
              Analizziamo gli ambienti, gli impianti esistenti e le necessità
              del cliente.
            </p>
          </div>
        </article>

        <article class="step">
          <span>02</span>

          <div>
            <h3>Proposta tecnica</h3>
            <p>
              Definiamo la soluzione, le apparecchiature e le modalità di
              intervento.
            </p>
          </div>
        </article>

        <article class="step">
          <span>03</span>

          <div>
            <h3>Installazione</h3>
            <p>
              Eseguiamo la posa in opera e il collegamento dei componenti
              previsti.
            </p>
          </div>
        </article>

        <article class="step">
          <span>04</span>

          <div>
            <h3>Verifica finale</h3>
            <p>
              Controlliamo il corretto funzionamento prima della consegna
              dell’impianto.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-box">
      <div>
        <span class="section-label light">Parliamo del tuo progetto</span>

        <h2>Devi installare o sostituire un impianto?</h2>

        <p>
          Contattaci per descrivere il lavoro e programmare un sopralluogo
          tecnico.
        </p>
      </div>

      <a href="/contatti/" class="cta-button">
        Contatta Elettromotor
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 120px 0;
    color: var(--white);
    background:
      radial-gradient(
        circle at 82% 25%,
        rgba(41, 184, 239, 0.28),
        transparent 30%
      ),
      linear-gradient(135deg, var(--navy), #0a477d);
  }

  .hero-content {
    max-width: 1180px;
  }

  .eyebrow,
  .section-label {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--cyan);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.8px;
    text-transform: uppercase;
  }

  .section-label {
    color: var(--blue);
  }

  .section-label.light {
    color: var(--cyan);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 950px;
    margin-bottom: 28px;
    font-size: clamp(48px, 6vw, 76px);
    line-height: 1;
    letter-spacing: -3px;
  }

  h1 strong {
    display: block;
    color: var(--cyan);
  }

  .page-hero p {
    max-width: 680px;
    margin-bottom: 32px;
    color: #cad8e7;
    font-size: 18px;
    line-height: 1.7;
  }

  .hero-button,
  .cta-button {
    min-height: 52px;
    padding: 0 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--navy);
    background: var(--white);
    border-radius: 7px;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
  }

  .services-section {
    padding: 110px 0;
  }

  .section-heading {
    margin-bottom: 50px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: end;
    gap: 60px;
  }

  h2 {
    margin-bottom: 0;
    color: var(--navy);
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.08;
    letter-spacing: -1.8px;
  }

  .section-heading > p {
    margin-bottom: 5px;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .service-card {
    min-height: 310px;
    padding: 34px;
    display: flex;
    flex-direction: column;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 14px;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 40px rgba(7, 24, 46, 0.1);
  }

  .service-number {
    margin-bottom: 55px;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
  }

  .service-card h3 {
    margin-bottom: 15px;
    color: var(--navy);
    font-size: 26px;
  }

  .service-card p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.75;
  }

  .service-card a {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    color: var(--navy);
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
  }

  .service-card a span {
    color: var(--blue);
    font-size: 20px;
  }

  .process-section {
    padding: 110px 0;
    color: var(--white);
    background: var(--navy);
  }

  .process-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 100px;
  }

  .process-intro h2 {
    margin-bottom: 25px;
    color: var(--white);
  }

  .process-intro p {
    color: #aebdd0;
    font-size: 16px;
    line-height: 1.75;
  }

  .steps {
    display: flex;
    flex-direction: column;
  }

  .step {
    padding: 25px 0;
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 22px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
  }

  .step > span {
    color: var(--cyan);
    font-size: 13px;
    font-weight: 800;
  }

  .step h3 {
    margin-bottom: 8px;
    font-size: 21px;
  }

  .step p {
    margin-bottom: 0;
    color: #aebdd0;
    font-size: 14px;
    line-height: 1.7;
  }

  .cta-section {
    padding: 55px 0;
  }

  .cta-box {
    padding: 60px;
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    align-items: center;
    gap: 60px;
    color: var(--white);
    background: linear-gradient(135deg, var(--blue), #045c9f);
    border-radius: 20px;
  }

  .cta-box h2 {
    margin-bottom: 18px;
    color: var(--white);
  }

  .cta-box p {
    max-width: 680px;
    margin-bottom: 0;
    color: #d8edff;
    line-height: 1.7;
  }

  .cta-button {
    justify-self: end;
  }

  @media (max-width: 850px) {
    .section-heading,
    .process-grid,
    .cta-box {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .cta-button {
      justify-self: start;
    }
  }

  @media (max-width: 650px) {
    .page-hero {
      padding: 75px 0;
    }

    h1 {
      font-size: 46px;
      letter-spacing: -2px;
    }

    .services-section,
    .process-section {
      padding: 75px 0;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      min-height: 280px;
    }

    .cta-section {
      padding: 25px 0;
    }

    .cta-box {
      padding: 40px 25px;
    }
  }
</style>