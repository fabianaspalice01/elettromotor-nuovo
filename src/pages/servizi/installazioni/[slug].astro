---
import { installationServices } from "../../../data/installazioni";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return installationServices.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const heroStyle = service.heroImage
  ? `--hero-image: url("${service.heroImage}")`
  : undefined;
---

<BaseLayout
  title={`${service.pageTitle} | Elettromotor`}
  description={service.description}
>
  <section
    class:list={["detail-hero", { "has-image": service.heroImage }]}
    style={heroStyle}
  >
    <div class="container">
      <div class="hero-content">
        <a class="back-link" href="/servizi/installazioni/">Installazioni</a>

        <span class="eyebrow">Servizi</span>

        <h1>{service.pageTitle}</h1>

        <p>{service.description}</p>
      </div>
    </div>
  </section>

  <section class="detail-content">
    <div class="container content-grid">
      <aside class="summary-card">
        <span>{service.number}</span>
        <strong>{service.title}</strong>
        <p>
          Richiedi un sopralluogo tecnico per valutare la soluzione piu adatta
          al tuo impianto.
        </p>
        <a href="/contatti/">Richiedi sopralluogo</a>
      </aside>

      <article class="article-content">
        <div class="intro">
          {service.intro.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <div class="sections">
          {
            service.sections.map((section) => (
              <section>
                <h2>{section.title}</h2>

                <p>{section.text}</p>

                <ul>
                  {section.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>

        {service.relatedServices && (
          <section class="related-section">
            <span>Approfondimenti</span>
            <h2>Tipologie di impianto antincendio</h2>

            <div class="related-grid">
              {service.relatedServices.map((item) => (
                <article class="related-card">
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                  <a href={`/servizi/installazioni/${service.slug}/${item.slug}/`}>
                    Scopri di piu
                  </a>
                </article>
              ))}
            </div>
          </section>
        )}
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .detail-hero {
    position: relative;
    overflow: hidden;
    padding: 125px 0 115px;
    color: var(--white);
    background:
      radial-gradient(
        circle at 84% 22%,
        rgba(41, 184, 239, 0.28),
        transparent 30%
      ),
      linear-gradient(135deg, var(--navy), #0a477d);
  }

  .detail-hero.has-image {
    background:
      linear-gradient(
        90deg,
        rgba(7, 24, 46, 0.94) 0%,
        rgba(7, 24, 46, 0.84) 42%,
        rgba(7, 24, 46, 0.56) 100%
      ),
      linear-gradient(
        180deg,
        rgba(7, 24, 46, 0.2),
        rgba(7, 24, 46, 0.7)
      ),
      var(--hero-image) center / cover no-repeat;
  }

  .detail-hero::after {
    content: "";
    position: absolute;
    right: -120px;
    bottom: -180px;
    width: 430px;
    height: 430px;
    border: 78px solid rgba(41, 184, 239, 0.12);
    border-radius: 50%;
    pointer-events: none;
  }

  .back-link,
  .eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.7px;
    text-transform: uppercase;
  }

  .back-link {
    margin-bottom: 24px;
    color: #d8edff;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--cyan);
  }

  .eyebrow {
    margin-bottom: 18px;
    color: var(--cyan);
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 790px;
    margin-bottom: 24px;
    font-size: clamp(46px, 6vw, 72px);
    line-height: 1;
    letter-spacing: -3px;
  }

  .hero-content > p {
    max-width: 690px;
    margin-bottom: 0;
    color: #d8edff;
    font-size: 18px;
    line-height: 1.75;
  }

  .detail-content {
    padding: 95px 0;
    background: var(--white);
  }

  .content-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 76px;
    align-items: start;
  }

  .summary-card {
    position: sticky;
    top: 125px;
    padding: 28px;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .summary-card span {
    display: block;
    margin-bottom: 42px;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
  }

  .summary-card strong {
    display: block;
    margin-bottom: 12px;
    color: var(--navy);
    font-size: 26px;
    line-height: 1.15;
  }

  .summary-card p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.7;
  }

  .summary-card a {
    min-height: 48px;
    padding: 0 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    background: var(--blue);
    border-radius: 7px;
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
  }

  .summary-card a:hover {
    background: var(--navy);
  }

  .article-content {
    max-width: 860px;
  }

  .intro {
    padding-bottom: 34px;
    border-bottom: 1px solid var(--border);
  }

  .intro p,
  .sections > section > p {
    color: var(--muted);
    font-size: 17px;
    line-height: 1.9;
  }

  .intro p:last-child {
    margin-bottom: 0;
  }

  .sections {
    display: grid;
    gap: 56px;
    padding-top: 56px;
  }

  .sections h2 {
    margin-bottom: 18px;
    color: var(--navy);
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.08;
    letter-spacing: -1.4px;
  }

  .sections ul {
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .sections li {
    position: relative;
    padding: 15px 0 15px 32px;
    border-bottom: 1px solid var(--border);
    color: var(--navy);
    font-size: 15px;
    font-weight: 800;
    line-height: 1.55;
  }

  .sections li::before {
    content: "+";
    position: absolute;
    left: 0;
    color: var(--blue);
    font-weight: 900;
  }

  .related-section {
    margin-top: 72px;
    padding-top: 58px;
    border-top: 1px solid var(--border);
  }

  .related-section > span {
    display: inline-block;
    margin-bottom: 16px;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .related-section > h2 {
    margin-bottom: 28px;
  }

  .related-grid {
    display: grid;
    gap: 18px;
  }

  .related-card {
    padding: 28px;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .related-card h3 {
    margin: 0 0 12px;
    color: var(--navy);
    font-size: 24px;
    line-height: 1.15;
  }

  .related-card p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.75;
  }

  .related-card a {
    color: var(--blue);
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
  }

  .related-card a:hover {
    color: var(--navy);
  }

  @media (max-width: 950px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .summary-card {
      position: static;
    }
  }

  @media (max-width: 650px) {
    .detail-hero {
      padding: 75px 0;
    }

    h1 {
      font-size: 44px;
      letter-spacing: -2px;
    }

    .detail-content {
      padding: 70px 0;
    }

    .sections {
      gap: 42px;
      padding-top: 42px;
    }
  }
</style>
