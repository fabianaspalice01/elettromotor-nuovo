---
import { designServices } from "../../../data/progettazione";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return designServices.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const heroStyle = `--hero-image: url("${service.heroImage}")`;
---

<BaseLayout
  title={`${service.pageTitle} | Elettromotor`}
  description={service.description}
>
  <section class="detail-hero has-image" style={heroStyle}>
    <div class="container">
      <div class="hero-content">
        <a class="back-link" href="/servizi/progettazione/">Progettazione</a>

        <span class="eyebrow">Servizi</span>

        <h1>{service.pageTitle}</h1>

        <p>{service.description}</p>
      </div>
    </div>
  </section>

  <section class="detail-content">
    <div class="container content-grid">
      <aside class="summary-card">
        <span>{service.number}</span>
        <strong>{service.title}</strong>
        <p>
          Richiedi una consulenza per valutare documenti, obblighi e requisiti
          della tua attivita.
        </p>
        <a href="/contatti/">Richiedi consulenza</a>
      </aside>

      <article class="article-content">
        <div class="intro">
          {service.intro.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <div class="sections">
          {
            service.sections.map((section) => (
              <section>
                <h2>{section.title}</h2>

                <p>{section.text}</p>

                <ul>
                  {section.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>

        <div class="document-box">
          <div>
            <span>Consulenza</span>
            <strong>Hai bisogno di supporto su questo servizio?</strong>
            <p>
              Raccontaci la tua situazione: ti aiuteremo a capire quali
              documenti, verifiche o passaggi sono necessari.
            </p>
          </div>

          <a href="/contatti/">Contattaci</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .detail-hero {
    position: relative;
    overflow: hidden;
    padding: 125px 0 115px;
    color: var(--white);
    background:
      linear-gradient(
        90deg,
        rgba(7, 24, 46, 0.94) 0%,
        rgba(7, 24, 46, 0.84) 42%,
        rgba(7, 24, 46, 0.56) 100%
      ),
      linear-gradient(
        180deg,
        rgba(7, 24, 46, 0.2),
        rgba(7, 24, 46, 0.7)
      ),
      var(--hero-image) center / cover no-repeat;
  }

  .detail-hero::after {
    content: "";
    position: absolute;
    right: -120px;
    bottom: -180px;
    width: 430px;
    height: 430px;
    border: 78px solid rgba(41, 184, 239, 0.12);
    border-radius: 50%;
    pointer-events: none;
  }

  .back-link,
  .eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.7px;
    text-transform: uppercase;
  }

  .back-link {
    margin-bottom: 24px;
    color: #d8edff;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--cyan);
  }

  .eyebrow {
    margin-bottom: 18px;
    color: var(--cyan);
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 24px;
    font-size: clamp(46px, 6vw, 72px);
    line-height: 1;
    letter-spacing: -3px;
  }

  .hero-content > p {
    max-width: 700px;
    margin-bottom: 0;
    color: #d8edff;
    font-size: 18px;
    line-height: 1.75;
  }

  .detail-content {
    padding: 95px 0;
    background: var(--white);
  }

  .content-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 76px;
    align-items: start;
  }

  .summary-card {
    position: sticky;
    top: 125px;
    padding: 28px;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .summary-card span {
    display: block;
    margin-bottom: 42px;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
  }

  .summary-card strong {
    display: block;
    margin-bottom: 12px;
    color: var(--navy);
    font-size: 26px;
    line-height: 1.15;
  }

  .summary-card p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.7;
  }

  .summary-card a,
  .document-box a {
    min-height: 48px;
    padding: 0 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    background: var(--blue);
    border-radius: 7px;
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
  }

  .summary-card a:hover,
  .document-box a:hover {
    background: var(--navy);
  }

  .article-content {
    max-width: 860px;
  }

  .intro {
    padding-bottom: 34px;
    border-bottom: 1px solid var(--border);
  }

  .intro p,
  .sections > section > p {
    color: var(--muted);
    font-size: 17px;
    line-height: 1.9;
  }

  .intro p:last-child {
    margin-bottom: 0;
  }

  .sections {
    display: grid;
    gap: 56px;
    padding-top: 56px;
  }

  .sections h2 {
    margin-bottom: 18px;
    color: var(--navy);
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.08;
    letter-spacing: -1.4px;
  }

  .sections ul {
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .sections li {
    position: relative;
    padding: 15px 0 15px 32px;
    border-bottom: 1px solid var(--border);
    color: var(--navy);
    font-size: 15px;
    font-weight: 800;
    line-height: 1.55;
  }

  .sections li::before {
    content: "+";
    position: absolute;
    left: 0;
    color: var(--blue);
    font-weight: 900;
  }

  .document-box {
    margin-top: 64px;
    padding: 32px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 32px;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .document-box span {
    display: block;
    margin-bottom: 10px;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.4px;
    text-transform: uppercase;
  }

  .document-box strong {
    display: block;
    margin-bottom: 10px;
    color: var(--navy);
    font-size: 24px;
  }

  .document-box p {
    margin-bottom: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  @media (max-width: 950px) {
    .content-grid,
    .document-box {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .summary-card {
      position: static;
    }

    .document-box a {
      justify-self: start;
    }
  }

  @media (max-width: 650px) {
    .detail-hero {
      padding: 75px 0;
    }

    h1 {
      font-size: 44px;
      letter-spacing: -2px;
    }

    .detail-content {
      padding: 70px 0;
    }

    .sections {
      gap: 42px;
      padding-top: 42px;
    }

    .document-box {
      padding: 24px;
    }
  }
</style>
