---
import { maintenanceServices } from "../../data/manutenzioni";
import BaseLayout from "../../layouts/BaseLayout.astro";

const checks = [
  "Verifica dello stato generale dell'impianto",
  "Controllo dei componenti soggetti a usura",
  "Pulizia, regolazione e sostituzione delle parti necessarie",
  "Prove di funzionamento e controllo finale",
  "Tracciabilita degli interventi eseguiti",
];
---

<BaseLayout
  title="Manutenzioni | Elettromotor"
  description="Manutenzione di estintori, porte REI, idranti, NASPI, sistemi di sollevamento idrico e impianti antincendio."
>
  <section class="page-hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">I nostri servizi</span>

        <h1>
          Manutenzioni puntuali
          <strong>per impianti sempre efficienti.</strong>
        </h1>

        <p>
          Organizziamo controlli periodici e interventi tecnici per mantenere
          gli impianti sicuri, funzionanti e conformi nel tempo.
        </p>

        <a class="hero-button" href="/contatti/">
          Programma un intervento
        </a>
      </div>

      <aside class="hero-panel" aria-label="Vantaggi della manutenzione">
        <span>Prevenzione</span>
        <strong>Ridurre i guasti e intervenire prima dell'emergenza.</strong>
        <p>
          La manutenzione programmata aiuta a controllare lo stato degli
          impianti e a pianificare gli interventi necessari.
        </p>
      </aside>
    </div>
  </section>

  <section class="services-section">
    <div class="container">
      <div class="section-heading">
        <div>
          <span class="section-label">Ambiti di intervento</span>

          <h2>Assistenza tecnica per impianti civili e industriali.</h2>
        </div>

        <p>
          Interveniamo su estintori, porte REI, idranti, NASPI, sistemi di
          sollevamento idrico e impianti antincendio soggetti a controllo
          periodico.
        </p>
      </div>

      <div class="services-grid">
        {
          maintenanceServices.map((service) => (
            <article class="service-card">
              <span class="service-number">{service.number}</span>

              <h3>{service.title}</h3>

              <p>{service.description}</p>

              <a href={`/servizi/manutenzioni/${service.slug}/`}>
                Leggi approfondimento
                <span>+</span>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="inspection-section">
    <div class="container inspection-grid">
      <div class="inspection-card">
        <span>Controllo periodico</span>
        <strong>Un piano ordinato evita interventi improvvisati.</strong>
      </div>

      <div class="inspection-content">
        <span class="section-label">Cosa controlliamo</span>

        <h2>Ogni intervento segue una verifica chiara.</h2>

        <p>
          La manutenzione viene organizzata in base al tipo di impianto, alla
          frequenza di utilizzo e alle condizioni operative. L'obiettivo e
          individuare anomalie, usure o inefficienze prima che diventino un
          problema.
        </p>

        <ul>
          {checks.map((check) => <li>{check}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-box">
      <div>
        <span class="section-label light">Assistenza e manutenzione</span>

        <h2>Vuoi programmare un controllo?</h2>

        <p>
          Contattaci per descrivere l'impianto e organizzare un intervento o
          un piano di manutenzione periodica.
        </p>
      </div>

      <a href="/contatti/" class="cta-button">
        Contatta Elettromotor
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 120px 0;
    color: var(--white);
    background:
      radial-gradient(
        circle at 82% 25%,
        rgba(41, 184, 239, 0.28),
        transparent 30%
      ),
      linear-gradient(135deg, var(--navy), #0a477d);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    align-items: end;
    gap: 70px;
  }

  .eyebrow,
  .section-label {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--cyan);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.8px;
    text-transform: uppercase;
  }

  .section-label {
    color: var(--blue);
  }

  .section-label.light {
    color: var(--cyan);
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 950px;
    margin-bottom: 28px;
    font-size: clamp(48px, 6vw, 76px);
    line-height: 1;
    letter-spacing: -3px;
  }

  h1 strong {
    display: block;
    color: var(--cyan);
  }

  .page-hero p {
    max-width: 680px;
    margin-bottom: 32px;
    color: #cad8e7;
    font-size: 18px;
    line-height: 1.7;
  }

  .hero-button,
  .cta-button {
    min-height: 52px;
    padding: 0 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--navy);
    background: var(--white);
    border-radius: 7px;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
  }

  .hero-panel {
    padding: 30px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 12px;
    backdrop-filter: blur(8px);
  }

  .hero-panel span {
    display: block;
    margin-bottom: 18px;
    color: var(--cyan);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .hero-panel strong {
    display: block;
    margin-bottom: 14px;
    color: var(--white);
    font-size: 25px;
    line-height: 1.2;
  }

  .hero-panel p {
    margin: 0;
    color: #d8edff;
    font-size: 14px;
  }

  .services-section,
  .inspection-section {
    padding: 110px 0;
  }

  .section-heading {
    margin-bottom: 50px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: end;
    gap: 60px;
  }

  h2 {
    margin-bottom: 0;
    color: var(--navy);
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.08;
    letter-spacing: -1.8px;
  }

  .section-heading > p,
  .inspection-content > p {
    margin-bottom: 5px;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.75;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 18px;
  }

  .service-card {
    min-height: 300px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    background: var(--background);
    border: 1px solid var(--border);
    border-radius: 14px;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 40px rgba(7, 24, 46, 0.1);
  }

  .service-number {
    margin-bottom: 42px;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
  }

  .service-card h3 {
    margin-bottom: 15px;
    color: var(--navy);
    font-size: 22px;
  }

  .service-card p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.75;
  }

  .service-card a {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    color: var(--navy);
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
  }

  .service-card a:hover {
    color: var(--blue);
  }

  .service-card a span {
    color: var(--blue);
    font-size: 20px;
  }

  .inspection-section {
    background: var(--background);
  }

  .inspection-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: 90px;
  }

  .inspection-card {
    min-height: 480px;
    padding: 36px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: var(--white);
    background:
      radial-gradient(
        circle at 70% 22%,
        rgba(41, 184, 239, 0.25),
        transparent 30%
      ),
      linear-gradient(145deg, var(--blue), var(--navy));
    border-radius: 20px;
  }

  .inspection-card span {
    margin-bottom: 14px;
    color: var(--cyan);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .inspection-card strong {
    max-width: 470px;
    font-size: 34px;
    line-height: 1.12;
  }

  .inspection-content p {
    margin: 22px 0 28px;
  }

  .inspection-content ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .inspection-content li {
    position: relative;
    padding: 14px 0 14px 30px;
    border-bottom: 1px solid var(--border);
    color: var(--navy);
    font-size: 15px;
    font-weight: 800;
  }

  .inspection-content li::before {
    content: "+";
    position: absolute;
    left: 0;
    color: var(--blue);
  }

  .cta-section {
    padding: 55px 0;
  }

  .cta-box {
    padding: 60px;
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    align-items: center;
    gap: 60px;
    color: var(--white);
    background: linear-gradient(135deg, var(--blue), #045c9f);
    border-radius: 20px;
  }

  .cta-box h2 {
    margin-bottom: 18px;
    color: var(--white);
  }

  .cta-box p {
    max-width: 680px;
    margin-bottom: 0;
    color: #d8edff;
    line-height: 1.7;
  }

  .cta-button {
    justify-self: end;
  }

  @media (max-width: 1200px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 1000px) {
    .hero-grid,
    .section-heading,
    .inspection-grid,
    .cta-box {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .hero-panel {
      max-width: 560px;
    }

    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .cta-button {
      justify-self: start;
    }
  }

  @media (max-width: 650px) {
    .page-hero {
      padding: 75px 0;
    }

    h1 {
      font-size: 46px;
      letter-spacing: -2px;
    }

    h2 {
      font-size: 36px;
    }

    .services-section,
    .inspection-section {
      padding: 75px 0;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      min-height: 280px;
    }

    .inspection-card {
      min-height: 380px;
      padding: 28px;
    }

    .inspection-card strong {
      font-size: 28px;
    }

    .cta-section {
      padding: 25px 0;
    }

    .cta-box {
      padding: 40px 25px;
    }
  }
</style>
